{
  "name": "interview-coder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm server:ensure && pnpm --dir server start & vite",
    "dev:frontend": "vite",
    "server": "pnpm server:ensure && pnpm --dir server start",
    "server:ensure": "npm --prefix server ci --ignore-scripts",
    "build": "node scripts/validate-env.mjs build && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-library": "node scripts/fetch-library.mjs && node scripts/build-concept-index.mjs",
    "build-concept-index": "node scripts/build-concept-index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:env:build": "node scripts/validate-env.mjs build",
    "validate:env:runtime": "node scripts/validate-env.mjs runtime",
    "validate:env:deploy": "node scripts/validate-env.mjs deploy",
    "deploy": "pnpm validate:env:deploy && pnpm build && wrangler pages deploy dist/ --project-name=swe-interview-prep",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.71",
    "@ai-sdk/google": "3.0.64",
    "@ai-sdk/openai": "3.0.53",
    "@ai-sdk/openai-compatible": "2.0.41",
    "@excalidraw/excalidraw": "0.18.1",
    "@libsql/client": "0.17.3",
    "@monaco-editor/react": "4.7.0",
    "@saas-maker/changelog-widget": "^0.2.1",
    "@saas-maker/feedback": "^0.2.1",
    "@saas-maker/posthog-client": "^0.1.0",
    "@saas-maker/testimonials": "^0.2.1",
    "ai": "6.0.168",
    "google-auth-library": "10.6.2",
    "highlight.js": "11.11.1",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.11.0",
    "lz-string": "1.5.0",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.10.0",
    "react-router-dom": "7.14.2",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "sucrase": "3.35.1",
    "ts-fsrs": "5.3.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@saas-maker/eslint-config": "^1.0.7",
    "@saas-maker/prettier-config": "^1.0.1",
    "@saas-maker/test-config": "0.2.0",
    "@saas-maker/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/lz-string": "1.5.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vercel/node": "5.7.13",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.5",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "happy-dom": "20.9.0",
    "husky": "^9.1.7",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "wrangler": "4.90.0"
  },
  "prettier": "@saas-maker/prettier-config",
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  }
}
