{
  "name": "interview-coder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm server:ensure && pnpm --dir server start & vite",
    "dev:frontend": "vite",
    "server": "pnpm server:ensure && pnpm --dir server start",
    "server:ensure": "npm --prefix server ci --ignore-scripts",
    "build": "node scripts/validate-env.mjs build && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-library": "node scripts/fetch-library.mjs && node scripts/build-concept-index.mjs && node scripts/ingest-library-rqs.mjs",
    "build-concept-index": "node scripts/build-concept-index.mjs",
    "ingest-library-rqs": "node scripts/ingest-library-rqs.mjs",
    "ingest-anki": "node scripts/ingest-anki.mjs",
    "ingest-leetcode": "node scripts/ingest-leetcode.mjs",
    "link-leetcode-drills": "node scripts/link-leetcode-drills.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:env:build": "node scripts/validate-env.mjs build",
    "validate:env:runtime": "node scripts/validate-env.mjs runtime",
    "validate:env:deploy": "node scripts/validate-env.mjs deploy",
    "deploy": "pnpm validate:env:deploy && pnpm build && wrangler pages deploy dist/ --project-name=swe-interview-prep",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.41",
    "@excalidraw/excalidraw": "0.18.1",
    "@libsql/client": "0.17.3",
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@saas-maker/changelog-widget": "^0.2.1",
    "@saas-maker/feedback": "^0.2.1",
    "@saas-maker/testimonials": "^0.2.1",
    "ai": "6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1",
    "google-auth-library": "10.6.2",
    "highlight.js": "11.11.1",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.11.0",
    "lz-string": "1.5.0",
    "motion": "^12.40.0",
    "posthog-js": "^1.372.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.10.0",
    "react-router-dom": "7.14.2",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "sql.js": "^1.14.1",
    "sucrase": "3.35.1",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "5.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/lz-string": "1.5.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@types/sql.js": "^1.4.11",
    "@vercel/node": "5.7.13",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "eslint": "9.39.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "happy-dom": "20.9.0",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "prettier": "3.8.3",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "wrangler": "4.90.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  }
}
