# Google OAuth (required for authentication)
GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# TursoDB (required for database)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT Secret (required for token signing)
JWT_SECRET=your-secret-key-change-in-production

# Old Supabase env vars (can be removed after migration)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
VITE_SAASMAKER_API_KEY=your-saas-maker-project-key

# Optional: override the API base URL used by the SPA.
# Defaults to http://localhost:3001 in dev, same-origin ("") in prod.
# VITE_API_URL=


